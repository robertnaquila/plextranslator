# Copy to .env and fill in. All values can also be passed as CLI flags.

# --- Plex connection (required) ---
# Base URL of your Plex Media Server, e.g. http://192.168.1.50:32400
PLEX_BASEURL=http://127.0.0.1:32400
# Plex auth token. See:
# https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=

# Optional: rewrite the media paths Plex reports to where they're mounted on THIS
# machine. Needed only when running off the Plex host (e.g. Plex on a Synology
# NAS, this app on a stronger PC). Format: "plex_prefix=>local_prefix", multiple
# separated by ';'. Example:
# PLEXTRANSLATOR_PATH_MAP=/volume1/video=>/mnt/plex
PLEXTRANSLATOR_PATH_MAP=

# --- Whisper / transcription ---
# Model size: tiny | base | small | medium | large-v3 (and distil-* variants).
# large-v3 gives the best KO/JA->EN translation; "small" or "medium" are good
# CPU-friendly compromises.
PLEXTRANSLATOR_WHISPER_MODEL=large-v3
# Compute device: auto | cpu | cuda
PLEXTRANSLATOR_DEVICE=auto
# Compute type: auto | int8 | int8_float16 | float16 | float32
PLEXTRANSLATOR_COMPUTE_TYPE=auto

# Where generated subtitle files are written when not written next to the media.
PLEXTRANSLATOR_OUTPUT_DIR=./subtitles_out

# --- Optional: refine Whisper's translation with Claude for natural English ---
PLEXTRANSLATOR_USE_LLM=false
ANTHROPIC_API_KEY=
# Claude model used for refinement.
PLEXTRANSLATOR_ANTHROPIC_MODEL=claude-opus-4-8

# --- Live mode tuning ---
# Seconds of audio processed per chunk while following playback.
PLEXTRANSLATOR_CHUNK_SECONDS=60
# Stay this many seconds ahead of the playhead before sleeping.
PLEXTRANSLATOR_LEAD_SECONDS=120
# How often (seconds) to poll Plex for the active session.
PLEXTRANSLATOR_POLL_INTERVAL=5
